@page
@model VideoGameManager.Pages.Games.IndexModel
@{
}
<h1>Games</h1>
<table>
	<thead>
		<tr>
			<th>Id</th>
			<th>Name</th>
			<th>Details</th>
			<th>Edit</th>
			<th>Delete</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var game in Model.Games)
		{
			<tr>
				<td>@game.Id</td>
				<td>@game.Title</td>
				<td><a asp-page="/Heroes/HeroDetail" asp-route-id="@game.Id" class="btn btn-info">Details</a></td>
				<td><a asp-page="/Heroes/HeroDetail" asp-route-id="@game.Id" class="btn btn-info">Edit</a></td>
				<td><a asp-page="/Heroes/HeroDetail" asp-route-id="@game.Id" class="btn btn-info">Delete</a></td>
			</tr>
		}
	</tbody>
</table>